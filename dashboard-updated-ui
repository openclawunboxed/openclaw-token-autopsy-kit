<script>
(function () {
  'use strict';

  /* ── THEME ──────────────────────────────────────────────────── */
  const root     = document.documentElement;
  const themeBtn = document.getElementById('themeBtn');
  const themeIcon = document.getElementById('themeIcon');
  let isLight = false;

  const THEMES = {
    dark: {
      '--bg':         '#0a0a0a',
      '--bg-2':       '#111111',
      '--bg-3':       '#1a1a1a',
      '--bg-4':       '#222222',
      '--bg-5':       '#2a2a2a',
      '--sep':        '#1f1f1f',
      '--border':     'rgba(255,255,255,.08)',
      '--border-md':  'rgba(255,255,255,.13)',
      '--border-lg':  'rgba(255,255,255,.20)',
      '--text-1':     '#ededed',
      '--text-2':     '#a1a1a1',
      '--text-3':     '#555555',
      '--text-inv':   '#0a0a0a',
      '--white':      '#ffffff',
      '--donut-hi':   '#ededed',
      '--donut-lo':   '#3a3a3a',
      '--donut-text': '#ededed',
      '--donut-sub':  '#555555',
    },
    light: {
      '--bg':         '#fafafa',
      '--bg-2':       '#ffffff',
      '--bg-3':       '#f4f4f5',
      '--bg-4':       '#e4e4e7',
      '--bg-5':       '#d4d4d8',
      '--sep':        '#e4e4e7',
      '--border':     'rgba(0,0,0,.07)',
      '--border-md':  'rgba(0,0,0,.12)',
      '--border-lg':  'rgba(0,0,0,.18)',
      '--text-1':     '#18181b',
      '--text-2':     '#52525b',
      '--text-3':     '#a1a1aa',
      '--text-inv':   '#fafafa',
      '--white':      '#18181b',
      '--donut-hi':   '#18181b',
      '--donut-lo':   '#d4d4d8',
      '--donut-text': '#18181b',
      '--donut-sub':  '#a1a1aa',
    }
  };

  function applyTheme(name) {
    const vars = THEMES[name];
    Object.entries(vars).forEach(([k, v]) => root.style.setProperty(k, v));
  }

  const SUN_PATH = `
    <circle cx="12" cy="12" r="5"/>
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42
             M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>`;
  const MOON_PATH = `<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>`;

  themeBtn.addEventListener('click', () => {
    isLight = !isLight;
    applyTheme(isLight ? 'light' : 'dark');
    themeIcon.innerHTML = isLight ? MOON_PATH : SUN_PATH;
    /* also flip the brand-mark background via --text-inv */
  });

  /* ── BAR ANIMATIONS ─────────────────────────────────────────── */
  function animateBars() {
    document.querySelectorAll('.bar-fill[data-pct]').forEach(el => {
      el.style.width = el.dataset.pct + '%';
    });
  }
  /* Delay slightly so the CSS transition fires */
  requestAnimationFrame(() => setTimeout(animateBars, 120));

  /* ── SCROLL SPY ─────────────────────────────────────────────── */
  const navLinks = Array.from(document.querySelectorAll('.nav-link[data-section]'));
  const sectionIds = navLinks.map(l => l.dataset.section);
  const mainEl = document.getElementById('main-scroll');

  function getActive() {
    /* Walk sections from bottom to top — first one scrolled past wins */
    const scrollTop = mainEl.scrollTop + 64; /* offset for topbar height */
    let active = sectionIds[0];
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (!el) continue;
      if (el.offsetTop <= scrollTop) active = id;
    }
    return active;
  }

  function updateSpy() {
    const active = getActive();
    navLinks.forEach(l => {
      l.classList.toggle('active', l.dataset.section === active);
    });
  }

  mainEl.addEventListener('scroll', updateSpy, { passive: true });
  updateSpy(); /* set initial state */

  /* Override spy briefly on nav click for instant feedback */
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      navLinks.forEach(l => l.classList.remove('active'));
      link.classList.add('active');
    });
  });

}());
</script>
