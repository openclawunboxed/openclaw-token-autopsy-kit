<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Token Autopsy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── DESIGN TOKENS ────────────────────────────────────────── */
    :root {
      --bg:         #0a0a0a;
      --bg-2:       #111111;
      --bg-3:       #1a1a1a;
      --bg-4:       #222222;
      --bg-5:       #2a2a2a;
      --border:     rgba(255,255,255,.08);
      --border-md:  rgba(255,255,255,.13);
      --border-lg:  rgba(255,255,255,.20);
      --sep:        #1f1f1f;        /* solid separator — no rgba needed */
      --text-1:     #ededed;
      --text-2:     #a1a1a1;
      --text-3:     #555555;
      --text-inv:   #0a0a0a;       /* text on light surfaces (brand mark) */
      --white:      #ffffff;
      --mono:       'Geist Mono', 'Fira Code', ui-monospace, monospace;
      --sans:       'Geist', ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --r:          8px;
      --r-lg:       12px;
      --topbar-h:   48px;
      --sidebar-w:  220px;
    }

    /* ── RESET ────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 14px; }
    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    a { text-decoration: none; color: inherit; }
    button { font-family: inherit; cursor: pointer; }

    /* ── LAYOUT ───────────────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      grid-template-rows: var(--topbar-h) 1fr;
      height: 100vh;
      overflow: hidden;
    }

    /* ── TOPBAR ───────────────────────────────────────────────── */
    .topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 18px;
      background: var(--bg);
      border-bottom: 1px solid var(--sep);
      z-index: 50;
      flex-shrink: 0;
    }
    .topbar-left { display: flex; align-items: center; gap: 16px; }

    /* Brand */
    .brand {
      display: flex; align-items: center; gap: 8px;
      font-size: .8125rem; font-weight: 600;
      color: var(--white); letter-spacing: -.015em;
    }
    .brand-mark {
      width: 22px; height: 22px;
      background: var(--white);
      border-radius: 5px;
      display: grid; place-items: center;
      flex-shrink: 0;
      transition: background .2s;
    }
    /* SVG uses currentColor so it flips with --text-inv */
    .brand-mark svg { display: block; color: var(--text-inv); }

    .sep-v { width: 1px; height: 16px; background: var(--sep); }

    .breadcrumb {
      display: flex; align-items: center; gap: 5px;
      font-size: .75rem; color: var(--text-3);
      letter-spacing: -.005em;
    }
    .breadcrumb strong { color: var(--text-2); font-weight: 500; }

    /* Topbar right */
    .topbar-right { display: flex; align-items: center; gap: 8px; }

    .pill {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: .6875rem; font-weight: 500;
      padding: 3px 9px; border-radius: 20px;
      border: 1px solid var(--border-md);
      color: var(--text-2);
      white-space: nowrap;
    }
    .pill.live {
      color: #22c55e;
      border-color: rgba(34,197,94,.28);
      background: rgba(34,197,94,.07);
    }
    .pill.live::before {
      content: '';
      width: 5px; height: 5px; border-radius: 50%;
      background: #22c55e;
      animation: blink 2.2s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    .icon-btn {
      width: 30px; height: 30px;
      border: 1px solid var(--sep);
      background: transparent;
      border-radius: var(--r);
      display: grid; place-items: center;
      color: var(--text-3);
      transition: border-color .15s, color .15s, background .15s;
    }
    .icon-btn:hover { border-color: var(--border-md); color: var(--text-1); background: var(--bg-3); }

    /* ── SIDEBAR ──────────────────────────────────────────────── */
    .sidebar {
      background: var(--bg);
      border-right: 1px solid var(--sep);
      padding: 14px 10px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }
    .nav-section-label {
      font-size: .6875rem; font-weight: 500;
      letter-spacing: .07em; text-transform: uppercase;
      color: var(--text-3);
      padding: 0 8px;
      margin: 14px 0 4px;
    }
    .nav-section-label:first-child { margin-top: 2px; }

    .nav-link {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 8px;
      border-radius: 6px;
      font-size: .8125rem; font-weight: 400;
      color: var(--text-2);
      border: 1px solid transparent;
      transition: background .12s, color .12s, border-color .12s;
      margin-bottom: 1px;
    }
    .nav-link:hover { background: var(--bg-3); color: var(--text-1); }
    .nav-link.active {
      background: var(--bg-3);
      color: var(--white);
      border-color: var(--border-md);
    }
    .nav-icon { width: 14px; height: 14px; flex-shrink: 0; opacity: .55; transition: opacity .12s; }
    .nav-link.active .nav-icon,
    .nav-link:hover  .nav-icon { opacity: 1; }
    .nav-count {
      margin-left: auto;
      font-size: .6875rem; font-family: var(--mono);
      color: var(--text-3);
    }

    /* ── MAIN SCROLL AREA ─────────────────────────────────────── */
    .main {
      overflow-y: auto;
      overflow-x: hidden;
      padding: 30px 32px 72px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    /* ── PAGE HEADER ──────────────────────────────────────────── */
    .page-hd {
      display: flex; align-items: flex-start;
      justify-content: space-between; gap: 16px;
    }
    .page-hd h1 {
      font-size: 1.0625rem; font-weight: 600;
      letter-spacing: -.03em; color: var(--white); line-height: 1.3;
    }
    .page-hd p { font-size: .75rem; color: var(--text-2); margin-top: 3px; }
    .meta-chip {
      font-size: .6875rem; font-family: var(--mono);
      color: var(--text-3);
      border: 1px solid var(--sep);
      border-radius: var(--r);
      padding: 5px 10px;
      background: var(--bg-2);
      white-space: nowrap; flex-shrink: 0;
    }

    /* ── SECTION LABEL ────────────────────────────────────────── */
    .section-label {
      display: flex; align-items: center; gap: 10px;
      font-size: .6875rem; font-weight: 500;
      letter-spacing: .07em; text-transform: uppercase;
      color: var(--text-3);
      margin-bottom: 12px;
    }
    .section-label::after {
      content: ''; flex: 1; height: 1px; background: var(--sep);
    }

    /* ── KPI GRID ─────────────────────────────────────────────── */
    /* Solid separator lines instead of rgba gap */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--sep);
      border-radius: var(--r-lg);
      overflow: hidden;
    }
    .kpi-cell {
      background: var(--bg-2);
      padding: 20px 22px;
      display: flex; flex-direction: column; gap: 8px;
      border-right: 1px solid var(--sep);
      transition: background .15s;
    }
    .kpi-cell:last-child { border-right: none; }
    .kpi-cell:hover { background: var(--bg-3); }
    .kpi-label {
      font-size: .6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: .07em;
      color: var(--text-3);
    }
    .kpi-val {
      font-size: 1.625rem; font-weight: 600;
      letter-spacing: -.045em; color: var(--white);
      line-height: 1; font-family: var(--mono);
    }
    .kpi-sub { font-size: .6875rem; color: var(--text-3); }

    /* ── CARD ─────────────────────────────────────────────────── */
    .card {
      background: var(--bg-2);
      border: 1px solid var(--sep);
      border-radius: var(--r-lg);
      overflow: hidden;
    }
    .card-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 13px 18px;
      border-bottom: 1px solid var(--sep);
      flex-shrink: 0;
    }
    .card-title {
      font-size: .8125rem; font-weight: 500;
      color: var(--text-1); letter-spacing: -.01em;
    }
    .card-body { padding: 18px; }

    /* ── GRID HELPERS ─────────────────────────────────────────── */
    .col-2   { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .col-2-3 { display: grid; grid-template-columns: 1.35fr 1fr; gap: 12px; }

    /* ── BAR CHART ────────────────────────────────────────────── */
    .bar-list { display: flex; flex-direction: column; gap: 14px; }
    .bar-item  { display: flex; flex-direction: column; gap: 5px; }
    .bar-meta  { display: flex; justify-content: space-between; align-items: baseline; }
    .bar-name  { font-size: .75rem; color: var(--text-2); font-weight: 500; }
    .bar-amt   { font-size: .75rem; font-family: var(--mono); color: var(--text-1); font-weight: 500; }
    .bar-track {
      width: 100%; height: 2px;
      background: var(--bg-5);
      border-radius: 99px; overflow: hidden;
    }
    .bar-fill {
      height: 100%; border-radius: 99px;
      background: var(--white);
      width: 0%;
      transition: width 1.1s cubic-bezier(.16,1,.3,1);
    }
    .bar-fill.mid { background: var(--text-2); }
    .bar-fill.dim { background: var(--text-3); }

    /* ── DONUT ────────────────────────────────────────────────── */
    .donut-wrap { display: flex; align-items: center; gap: 22px; }
    .donut-svg  { flex-shrink: 0; display: block; }
    .legend     { display: flex; flex-direction: column; gap: 9px; flex: 1; min-width: 0; }
    .legend-row {
      display: flex; align-items: center;
      justify-content: space-between; gap: 8px;
    }
    .legend-left  { display: flex; align-items: center; gap: 7px; min-width: 0; }
    .legend-dot   { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .legend-name  { font-size: .75rem; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .legend-pct   { font-size: .6875rem; font-family: var(--mono); color: var(--text-3); flex-shrink: 0; }

    /* ── TABLE ────────────────────────────────────────────────── */
    .tbl-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      padding: 9px 16px;
      font-size: .6875rem; font-weight: 500;
      letter-spacing: .06em; text-transform: uppercase;
      color: var(--text-3);
      background: var(--bg-2);
      border-bottom: 1px solid var(--sep);
      text-align: left;
      white-space: nowrap;
    }
    tbody tr {
      border-bottom: 1px solid var(--sep);
      transition: background .1s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg-3); }
    tbody td { padding: 11px 16px; font-size: .8125rem; color: var(--text-1); }
    .td-mono { font-family: var(--mono); font-size: .75rem; color: var(--text-2); }

    /* Agent */
    .agent-cell { display: flex; align-items: center; gap: 8px; }
    .av {
      width: 22px; height: 22px; border-radius: 5px;
      border: 1px solid var(--border-md);
      display: grid; place-items: center;
      font-size: .5625rem; font-weight: 700; letter-spacing: .02em;
      color: var(--text-2); background: var(--bg-4);
      flex-shrink: 0; font-family: var(--mono);
    }

    /* Tags */
    .tag {
      display: inline-flex; align-items: center;
      font-size: .6875rem; font-weight: 500;
      padding: 2px 7px; border-radius: 5px;
      border: 1px solid var(--sep);
      color: var(--text-2); background: var(--bg-3);
      letter-spacing: .01em; white-space: nowrap;
    }
    .tag.em { color: var(--text-1); border-color: var(--border-md); background: var(--bg-4); }

    /* Cost */
    .cost { font-family: var(--mono); font-size: .75rem; font-weight: 500; }
    .cost.hi  { color: var(--white); }
    .cost.mid { color: var(--text-2); }
    .cost.lo  { color: var(--text-3); }

    /* ── AUDIT LIST ───────────────────────────────────────────── */
    .audit-list { display: flex; flex-direction: column; }
    .audit-item {
      display: flex; gap: 13px; align-items: flex-start;
      padding: 14px 0;
      border-bottom: 1px solid var(--sep);
    }
    .audit-item:last-child { border-bottom: none; padding-bottom: 0; }
    .audit-item:first-child { padding-top: 0; }
    .audit-num {
      width: 20px; height: 20px; border-radius: 5px;
      border: 1px solid var(--border-md);
      display: grid; place-items: center;
      font-size: .625rem; font-family: var(--mono); font-weight: 600;
      color: var(--text-3); flex-shrink: 0; margin-top: 1px;
    }
    .audit-title {
      font-size: .8125rem; font-weight: 500;
      color: var(--text-1); margin-bottom: 3px; letter-spacing: -.01em;
    }
    .audit-body { font-size: .75rem; color: var(--text-2); line-height: 1.65; }

    /* ── RECO LIST ────────────────────────────────────────────── */
    .reco-list { display: flex; flex-direction: column; gap: 7px; }
    .reco-item {
      display: flex; align-items: flex-start; gap: 11px;
      padding: 12px 14px;
      border: 1px solid var(--sep);
      border-radius: var(--r);
      background: var(--bg-3);
      transition: border-color .15s, background .15s;
    }
    .reco-item:hover { border-color: var(--border-md); background: var(--bg-4); }
    .reco-icon {
      width: 26px; height: 26px; border-radius: 6px;
      border: 1px solid var(--border-md);
      display: grid; place-items: center;
      flex-shrink: 0; font-size: 12px; background: var(--bg-2);
    }
    .reco-title {
      font-size: .8125rem; font-weight: 500;
      color: var(--text-1); margin-bottom: 2px; letter-spacing: -.01em;
    }
    .reco-body { font-size: .75rem; color: var(--text-2); line-height: 1.6; }

    /* ── INLINE CODE ──────────────────────────────────────────── */
    .ic {
      font-family: var(--mono); font-size: .6875rem;
      background: var(--bg-4); border: 1px solid var(--border-md);
      border-radius: 4px; padding: 1px 5px;
      color: var(--text-1);
    }

    /* ── ANOMALY SECTION ──────────────────────────────────────── */
    .anomaly-table {
      border: 1px solid var(--sep);
      border-radius: var(--r-lg);
      overflow: hidden;
    }
    .at-head {
      display: flex;
      background: var(--bg-2);
      border-bottom: 1px solid var(--sep);
    }
    .at-row {
      display: flex;
      background: var(--bg-2);
      border-bottom: 1px solid var(--sep);
      transition: background .1s;
    }
    .at-row:last-child { border-bottom: none; }
    .at-row:hover { background: var(--bg-3); }
    .at-cell {
      padding: 11px 16px;
      border-right: 1px solid var(--sep);
      font-size: .75rem;
      flex-shrink: 0;
    }
    .at-cell:last-child { border-right: none; }
    .at-cell.c-name { min-width: 120px; }
    .at-cell.c-data { flex: 1; display: flex; align-items: center; gap: 28px; }
    .at-cell.c-badge { min-width: 108px; display: flex; align-items: center; }
    .at-head-cell {
      padding: 8px 16px;
      border-right: 1px solid var(--sep);
      font-size: .6875rem; font-weight: 500;
      letter-spacing: .06em; text-transform: uppercase;
      color: var(--text-3); flex-shrink: 0;
    }
    .at-head-cell:last-child { border-right: none; }
    .at-head-cell.c-name { min-width: 120px; }
    .at-head-cell.c-data { flex: 1; }
    .at-head-cell.c-badge { min-width: 108px; }

    .kv { display: flex; flex-direction: column; gap: 1px; }
    .kv-k { font-size: .625rem; color: var(--text-3); text-transform: uppercase; letter-spacing: .06em; font-weight: 500; }
    .kv-v { font-family: var(--mono); font-size: .75rem; color: var(--text-1); font-weight: 500; }

    .delta {
      display: inline-flex; align-items: center; gap: 3px;
      font-family: var(--mono); font-size: .75rem; font-weight: 600;
      padding: 3px 8px; border-radius: 5px;
    }
    .delta.up   { color: #f87171; background: rgba(248,113,113,.09); border: 1px solid rgba(248,113,113,.18); }
    .delta.down { color: #4ade80; background: rgba(74,222,128,.07);  border: 1px solid rgba(74,222,128,.15); }

    /* ── SCROLLBAR ────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--bg-5); border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-3); }

    /* ── RESPONSIVE ───────────────────────────────────────────── */
    @media (max-width: 900px) {
      .layout {
        grid-template-columns: 1fr;
        grid-template-rows: var(--topbar-h) auto 1fr;
        height: auto;
        overflow: visible;
      }
      .sidebar {
        flex-direction: row; flex-wrap: wrap; gap: 4px;
        border-right: none; border-bottom: 1px solid var(--sep);
        padding: 8px 10px; overflow-y: visible; overflow-x: auto;
      }
      .nav-section-label { display: none; }
      .nav-link { margin-bottom: 0; }
      .main { overflow: visible; }
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .kpi-cell:nth-child(2) { border-right: none; }
      .kpi-cell:nth-child(3),
      .kpi-cell:nth-child(4) { border-top: 1px solid var(--sep); }
      .col-2, .col-2-3 { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .main { padding: 20px 14px 56px; gap: 20px; }
      .kpi-grid { grid-template-columns: 1fr 1fr; }
      .kpi-val { font-size: 1.25rem; }
      .page-hd { flex-direction: column; gap: 8px; }
      .at-cell.c-data { gap: 16px; }
    }

    /* ── FADE-IN ANIMATIONS ───────────────────────────────────── */
    .fade { opacity: 0; transform: translateY(7px); animation: fadeUp .42s ease forwards; }
    .d0 { animation-delay: 0s; }
    .d1 { animation-delay: .07s; }
    .d2 { animation-delay: .14s; }
    .d3 { animation-delay: .21s; }
    .d4 { animation-delay: .28s; }
    .d5 { animation-delay: .35s; }
    @keyframes fadeUp { to { opacity: 1; transform: none; } }
  </style>
</head>
<body>
<div class="layout">

  <!-- ── TOPBAR ─────────────────────────────────────────────── -->
  <header class="topbar">
    <div class="topbar-left">
      <a href="#" class="brand">
        <div class="brand-mark">
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 9.5L6 2.5L10 9.5" stroke="currentColor" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        Token Autopsy
      </a>
      <div class="sep-v" aria-hidden="true"></div>
      <div class="breadcrumb">Reports&thinsp;/&thinsp;<strong>Run #2841</strong></div>
    </div>
    <div class="topbar-right">
      <span class="pill live">Live</span>
      <span class="pill">Jul 14, 2025</span>
      <button class="icon-btn" id="themeBtn" title="Toggle light / dark" aria-label="Toggle theme">
        <!-- sun icon (dark mode default — click to go light) -->
        <svg id="themeIcon" width="13" height="13" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42
                   M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>
      <button class="icon-btn" title="Export report" aria-label="Export report">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ── SIDEBAR ────────────────────────────────────────────── -->
  <nav class="sidebar" aria-label="Dashboard navigation">
    <div class="nav-section-label">Overview</div>

    <a href="#overview" class="nav-link active" data-section="overview">
      <svg class="nav-icon" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="1" y="1" width="5" height="5" rx="1"/>
        <rect x="8" y="1" width="5" height="5" rx="1"/>
        <rect x="1" y="8" width="5" height="5" rx="1"/>
        <rect x="8" y="8" width="5" height="5" rx="1"/>
      </svg>
      Dashboard
    </a>

    <a href="#costs" class="nav-link" data-section="costs">
      <svg class="nav-icon" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M7 1v12M4.5 4C4.5 2.9 5.6 2 7 2s2.5.9 2.5 2S8.4 6 7 6 4.5 7 4.5 8s1.1 2 2.5 2 2.5-.9 2.5-2"/>
